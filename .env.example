# Required: Anthropic API key for the agent's LLM calls
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: Silicon Analysts API key for MCP tool access
# Get a free key at https://siliconanalysts.com/developers
# Free tier: ~10 queries/day (100 API calls/day, ~10 calls per query)
SILICON_ANALYSTS_API_KEY=sa_live_...

# Optional: MCP endpoint (defaults to production)
SILICON_ANALYSTS_MCP_URL=https://siliconanalysts.com/api/mcp

# Optional: Anthropic model to use (default: claude-sonnet-4-5)
# Use claude-opus-4 for more thorough reasoning at ~5x cost
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: Maximum agent reasoning turns (default: 10)
MAX_AGENT_TURNS=10
